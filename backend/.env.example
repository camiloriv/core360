# ==========================================
# Core360 — Backend Environment Variables
# ==========================================

# Database (Railway provee estas automáticamente)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=core360

# Server
PORT=8080
NODE_ENV=production
FRONTEND_URL=https://core360.pages.dev

# JWT
JWT_SECRET=mi_clave_secreta_segura

# Microsoft Azure AD (Correos y Sincronización Teams)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=tu_client_secret
SMTP_USER=minutas@proforma.cl

# Desarrollo (Opcionales)
# REDIRECT_EMAILS_TO=dev@proforma.cl
# RESET_PASSWORDS_DEV=true
