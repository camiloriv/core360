# ==========================================
# Core360 — Backend Environment Variables
# ==========================================

# Database (Railway provee estas automáticamente)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=core360

# Server
PORT=8080
NODE_ENV=production

# Frontend URL (para CORS) — Cambiar al dominio real en producción
FRONTEND_URL=https://core360.pages.dev

# Email (SMTP Office 365)
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USER=minutas@proforma.cl
MAIL_PASS=your_mail_password
